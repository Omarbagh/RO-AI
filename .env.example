# ============================================================================
# CVhero environment variables
# Copy to `.env.local` and fill in real values. Never commit `.env.local`.
# Anything WITHOUT the NEXT_PUBLIC_ prefix is server-only and must never be
# referenced from client components.
# ============================================================================

# --- App -------------------------------------------------------------------
# Public base URL of the app (used for OAuth redirects, Mollie redirect/webhook).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Supabase --------------------------------------------------------------
# Project URL + anon key are safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service role key bypasses RLS — SERVER ONLY (webhooks, AI usage writes).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Anthropic (Claude) ----------------------------------------------------
# Server-only. All Claude calls go through server routes, never the client.
ANTHROPIC_API_KEY=sk-ant-your-key
# Default model for AI features.
ANTHROPIC_MODEL=claude-opus-4-8

# --- Mollie (payments) -----------------------------------------------------
# Use a test key (test_...) in development.
MOLLIE_API_KEY=test_your-mollie-key
# Pro plan recurring price (EUR) and interval for Mollie subscriptions.
MOLLIE_PRO_PRICE_EUR=9.99
MOLLIE_PRO_INTERVAL=1 month
